# Copy to .env.local for local dev. These are also set as GitHub repo
# secrets/vars and inlined into the build by the Pages workflow.
# The anon key is safe to expose publicly; RLS is the real security boundary.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
